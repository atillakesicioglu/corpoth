# =============================================================
# Corpoth - Apache yapilandirmasi
# =============================================================

# index.php varsayilan dokuman
DirectoryIndex index.php index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  # index.html cagrildiginda index.php'ye yonlendir (eski URL korunsun)
  RewriteRule ^index\.html$ /index.php [R=301,L]

  # Trailing slash
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# -------------------------------------------------------------
# Hassas klasor/dosyalari koru
# -------------------------------------------------------------
<IfModule mod_authz_core.c>
  <FilesMatch "(\.env|config\.php|composer\.(json|lock))$">
    Require all denied
  </FilesMatch>
</IfModule>

<IfModule !mod_authz_core.c>
  <FilesMatch "(\.env|config\.php|composer\.(json|lock))$">
    Order allow,deny
    Deny from all
  </FilesMatch>
</IfModule>

# /includes /db klasorlerine direkt erisim engellenir
RedirectMatch 403 ^/(includes|db)(/.*)?$

# -------------------------------------------------------------
# Compression
# -------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# -------------------------------------------------------------
# Browser Caching
# -------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault                              "access plus 1 month"
  ExpiresByType text/html                     "access plus 0 seconds"
  ExpiresByType text/css                      "access plus 1 year"
  ExpiresByType application/javascript        "access plus 1 year"
  ExpiresByType image/jpeg                    "access plus 1 year"
  ExpiresByType image/png                     "access plus 1 year"
  ExpiresByType image/webp                    "access plus 1 year"
  ExpiresByType image/svg+xml                 "access plus 1 year"
  ExpiresByType image/x-icon                  "access plus 1 year"
  ExpiresByType font/woff2                    "access plus 1 year"
  ExpiresByType application/font-woff2        "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|jpg|jpeg|png|webp|gif|svg|ico|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(php|html)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>

  # Guvenlik header'lari
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# -------------------------------------------------------------
# Hata sayfalari (PHP'ye yonlendir, custom yapilabilir)
# -------------------------------------------------------------
ErrorDocument 404 /index.php
